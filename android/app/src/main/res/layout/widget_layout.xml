<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E2E"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CAMPUSLY LIVE SCHEDULE"
        android:textColor="#CBA6F7"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#181825"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/widget_ongoing_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ONGOING NOW"
            android:textColor="#A6E3A1"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_ongoing_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Loading Ongoing Class..."
            android:textColor="#CDD6F4"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_ongoing_room"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Room &amp; Time"
            android:textColor="#A6ADC8"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#181825"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/widget_next_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UPCOMING NEXT"
            android:textColor="#89B4FA"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_next_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Loading Next Class..."
            android:textColor="#CDD6F4"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_next_room"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Starts in..."
            android:textColor="#A6ADC8"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
